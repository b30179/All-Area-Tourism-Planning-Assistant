# ============================================================
# 全域旅游规划助手 - 环境变量配置样例
# ============================================================
# 复制本文件为 .env，并填入你的真实 API Key
# 优先级：Streamlit 侧边栏输入 > .env 文件 > 代码默认值
# ============================================================

# ===== LLM 大模型配置（OpenAI 兼容接口）=====
# 推荐服务商（任选其一）：
#   1. 腾讯 TokenHub MaaS: https://tokenhub.tencentmaas.com/
#   2. OpenAI 官方:        https://platform.openai.com/
#   3. DeepSeek:           https://platform.deepseek.com/
#   4. 月之暗面 Kimi:      https://platform.moonshot.cn/
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://tokenhub.tencentmaas.com/v1
LLM_MODEL=kimi-k2.7-code

# ===== 工具 API 配置（可选）=====
# 腾讯位置服务 LBS：https://lbs.qq.com/  (POI检索首选)
TENCENT_LBS_KEY=

# 百度地图开放平台：https://lbsyun.baidu.com/  (POI检索兜底)
BAIDU_MAP_AK=

# ===== 运行参数（可选）=====
# 工具调用最大轮次（防死循环）
MAX_TOOL_ROUNDS=4
# wttr.in 天气API超时（秒）
WEATHER_TIMEOUT=10